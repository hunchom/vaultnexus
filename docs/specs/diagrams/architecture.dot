digraph VaultNexus {
  rankdir=TB; bgcolor="white"; compound=true;
  graph [dpi=200, fontname="Helvetica-Bold", fontsize=16, labeljust="l", margin=14, ranksep=0.85, nodesep=0.5];
  node  [fontname="Helvetica", fontsize=13, shape=box, style="rounded,filled", penwidth=1.2, color="#888888", fillcolor="#ffffff", margin="0.16,0.09"];
  edge  [fontname="Helvetica", fontsize=11, color="#555555"];

  /* ---- CLIENTS (top row) ---- */
  subgraph cluster_clients {
    label="THIN CLIENTS  ·  zero embed / index / search";
    style="rounded,filled"; color="#9cc7f0"; fillcolor="#eaf4ff"; fontcolor="#0b4a82";
    cc    [label="Claude Code\nstdio shim"];
    obs   [label="Obsidian\nthin plugin · 60fps"];
    other [label="Desktop / Cursor\nHTTP-MCP"];
    {rank=same; cc; obs; other;}
  }

  ipc [label="IPC  ·  Unix socket (default)  +  loopback HTTP (hardened)",
       shape=note, fillcolor="#fff7d6", color="#e0c200", fontsize=12];

  /* ---- ENGINE (middle) ---- */
  subgraph cluster_engine {
    label="VAULTNEXUS ENGINE  (daemon)  ·  100% CPU  ·  SINGLE WRITER";
    style="rounded,filled"; color="#74c98c"; fillcolor="#e9fbef"; fontcolor="#0d5a2a";
    mcp   [label="MCP surface\ntools · resources", fillcolor="#f2fff6"];
    idx   [label="Indexer\nwatch→parse→chunk→\nembed→Claim Index", fillcolor="#f2fff6"];
    ret   [label="Retriever\nhybrid RRF→expand→\nrerank→cited", fillcolor="#f2fff6"];
    sen   [label="Sentinel\ncull→assert→Judge→\nreframe→learn", fillcolor="#f2fff6"];
    store [label="Postgres+pgvector (MVCC)\nvectors·FTS·links·claims·\nlabels·cache  (sqlite fallback)",
           shape=cylinder, fillcolor="#f3e9ff", color="#a86fd8"];
    {rank=same; idx; ret; sen;}
  }

  /* ---- EXTERNAL APIs (below engine) ---- */
  subgraph cluster_ext {
    label="PROVIDER REGISTRY  ·  any vendor · local OR API · bring-what-you-have";
    style="rounded,filled"; color="#f0a875"; fillcolor="#fff1e8"; fontcolor="#9a4a16";
    emb   [label="1. Embedding model\n(required)\nGemini·Nomic·Gemma·local…", fillcolor="#fff8f2"];
    rr    [label="2. Reranker\n(optional → skip)\nVoyage·Cohere·zerank…", fillcolor="#fff8f2"];
    judge [label="3. LLM / Judge\n(host session or yours)\nClaude·GPT·Gemini·local", fillcolor="#fff8f2"];
    {rank=same; emb; rr; judge;}
  }

  /* ---- VAULT (bottom) ---- */
  subgraph cluster_vault {
    label="VAULT  ·  local · your data";
    style="rounded,filled"; color="#b5b5b5"; fillcolor="#f2f2f2"; fontcolor="#333333";
    md  [label="*.md", shape=folder];
    git [label="git history", shape=folder];
    {rank=same; md; git;}
  }

  /* ---- spine (vertical) ---- */
  cc -> ipc; obs -> ipc; other -> ipc;
  ipc -> mcp;
  mcp -> idx; mcp -> ret; mcp -> sen;
  idx -> store; ret -> store [dir=both]; sen -> store [dir=both];
  store -> emb [style=invis];           /* push external below engine */

  /* ---- engine -> external ---- */
  idx -> emb [label="embed"];
  ret -> rr  [label="top-30"];
  sen -> judge [label="adjudicate"];

  /* ---- vault (bottom, back-edges don't reshape ranks) ---- */
  emb -> md [style=invis];
  md  -> idx [label="watch", style=dashed, constraint=false];
  git -> sen [label="log -G", style=dashed, constraint=false];
  sen -> md  [label="FS write", style=dashed, constraint=false];
}
