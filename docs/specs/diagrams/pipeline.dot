digraph Pipeline {
  rankdir=TB;
  bgcolor="white";
  graph [dpi=200, fontname="Helvetica-Bold", fontsize=15, labeljust="l",
         margin=16, ranksep=1.0, nodesep=0.5];
  node  [fontname="Helvetica", fontsize=12, shape=box, style="rounded,filled",
         penwidth=1.1, color="#888888", fillcolor="#ffffff", margin="0.18,0.10"];
  edge  [fontname="Helvetica", fontsize=10, color="#555555"];

  /* ======================================================
     TOP: INDEX PATH
     ====================================================== */
  subgraph cluster_index {
    label="INDEX PATH  (incremental · content-hash cached)";
    style="rounded,filled"; color="#74c98c"; fillcolor="#e9fbef"; fontcolor="#0d5a2a";

    i_md    [label="vault/*.md", shape=folder, fillcolor="#f2fff6"];
    i_parse [label="parse  (remark + Quartz OFM)\nwikilink resolve · tags · ^blocks",
             fillcolor="#f2fff6"];
    i_chunk [label="hierarchical chunk\nsentence / chunk / note\noffset-faithful  +  BM25 blurb",
             fillcolor="#f2fff6"];
    i_embed [label="embed(doc)\nregistered embedder\n(contextual if supported · resident-local option)",
             fillcolor="#f2fff6"];
    i_claim [label="sentence tier → Claim Index\n(assertion pre-filter)",
             fillcolor="#f2fff6"];
    i_knn   [label="build kNN adjacency graph\n(usearch · k≈8-16)\nshared: expansion + convergence edges",
             fillcolor="#f2fff6"];
    i_store [label="store\nbinary codes + int8 rescore\n+  FTS5 row  +  kNN CSR",
             shape=cylinder, fillcolor="#f3e9ff", color="#a86fd8"];

    i_md    -> i_parse [label="chokidar"];
    i_parse -> i_chunk;
    i_chunk -> i_embed;
    i_chunk -> i_claim;
    i_embed -> i_knn;
    i_embed -> i_store [label="vectors"];
    i_claim -> i_store [label="claims"];
    i_knn   -> i_store [label="CSR graph"];
  }

  /* ======================================================
     BOTTOM-LEFT: QUERY PATH
     ====================================================== */
  subgraph cluster_query {
    label="QUERY PATH  (hot path · zero generative LLM)";
    style="rounded,filled"; color="#9cc7f0"; fillcolor="#eaf4ff"; fontcolor="#0b4a82";

    q_in    [label="query", fillcolor="#dceeff"];

    q_rtr   [label="ROUTER\ncached TF-IDF/SVM + heuristics\n~0.1ms · NO embed call\n→ α-prior · expansion flag · rerank-disposition",
             fillcolor="#dceeff"];

    /* first-stage parallel */
    q_emb   [label="embed(query)\nregistered embedder"];
    q_bm    [label="BM25\n(FTS5)"];
    q_wl    [label="wikilink-CTE\n(1-hop frontier)"];
    {rank=same; q_emb; q_bm; q_wl;}

    q_fuse  [label="CC / TMM fusion\n(IDF-adaptive α · RRF cold-start)\n→ fused pool"];

    q_gate  [label="CONFIDENCE GATE\ntop1−top2 gap · lexical∩semantic · entropy\n(free · self-warms from eval labels)"];

    /* HIGH branch */
    q_hi    [label="HIGH confidence\n→ early-exit", fillcolor="#d4f7dc"];
    q_dpp_h [label="DPP coverage select\n→ adaptive-k", fillcolor="#d4f7dc"];

    /* LOW branch */
    q_lo    [label="LOW confidence\n→ GAR/RGS expansion", fillcolor="#fff3cd"];
    q_gar   [label="GAR/RGS adaptive expansion\nrerank batch\n→ kNN + wikilink neighbors\nof cross-encoder-confirmed notes\n→ rerank → repeat (in budget)",
             fillcolor="#fff3cd"];
    q_dpp_l [label="DPP coverage select\n→ adaptive-k", fillcolor="#fff3cd"];

    q_out   [label="cited hits\npath#heading^block · snippet · score · why-retrieved",
             fillcolor="#c8e6ff"];

    q_in  -> q_rtr;
    q_rtr -> q_emb;
    q_rtr -> q_bm;
    q_rtr -> q_wl;
    q_emb -> q_fuse;
    q_bm  -> q_fuse;
    q_wl  -> q_fuse;
    q_fuse -> q_gate;
    q_gate -> q_hi [label="HIGH"];
    q_gate -> q_lo [label="LOW"];
    q_hi   -> q_dpp_h;
    q_lo   -> q_gar;
    q_gar  -> q_dpp_l;
    q_dpp_h -> q_out;
    q_dpp_l -> q_out;
  }

  /* store feeds query */
  i_store -> q_fuse [label="vec scan (simsimd)\n+ BM25 (FTS5)",
                     style=dashed, color="#a86fd8", fontcolor="#a86fd8"];
  i_store -> q_gar  [label="kNN graph\n+ wikilink CSR",
                     style=dashed, color="#a86fd8", fontcolor="#a86fd8"];
}
