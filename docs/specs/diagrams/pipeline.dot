digraph Pipeline {
  rankdir=LR;
  bgcolor="white";
  nodesep=0.3; ranksep=0.5;
  node  [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled", penwidth=1.0, color="#888888", fillcolor="#ffffff"];
  edge  [fontname="Helvetica", fontsize=8, color="#555555"];
  graph [fontname="Helvetica-Bold", fontsize=12, labeljust="l", margin=10];

  /* ---------------- INDEX ---------------- */
  subgraph cluster_index {
    label="INDEX  (incremental · content-hash cached)";
    style="rounded,filled"; color="#74c98c"; fillcolor="#e9fbef"; fontcolor="#0d5a2a";
    i_md    [label="vault/*.md", shape=folder];
    i_parse [label="parse\nremark + Quartz ofm\n(wikilink resolve, tags, ^blocks)"];
    i_chunk [label="chunk\nheader→512tok · offset-faithful\n+ BM25 blurb"];
    i_embed [label="embed(doc)\nembedding registry (API)"];
    i_sent  [label="sentence-split\n→ Claim Index\n(assertion pre-filter)"];
    i_md -> i_parse [label="chokidar"];
    i_parse -> i_chunk -> i_embed;
    i_parse -> i_sent;
  }

  /* ---------------- STORE ---------------- */
  store [label="SQLite (single writer)\nvec_chunks(model-dim) · fts_chunks\nlinks · claims · vec_claims\nlabels · hash-cache",
         shape=cylinder, fillcolor="#f3e9ff", color="#a86fd8", fontsize=10];
  i_embed -> store; i_sent -> store;

  /* ---------------- QUERY ---------------- */
  subgraph cluster_query {
    label="QUERY";
    style="rounded,filled"; color="#9cc7f0"; fillcolor="#eaf4ff"; fontcolor="#0b4a82";
    q_in   [label="query"];
    q_eq   [label="embed(query)\nregistry (API)"];
    q_bm   [label="BM25 (FTS5)"];
    q_rrf  [label="hybrid RRF\n(k=60) → pool"];
    q_exp  [label="1-hop wikilink\nexpansion (CTE)"];
    q_rr   [label="Voyage rerank-2.5\n→ top 5-8"];
    q_out  [label="cited hits\npath#heading^block", fillcolor="#eaf4ff"];
    q_in -> q_eq; q_in -> q_bm;
    q_eq -> q_rrf; q_bm -> q_rrf;
    q_rrf -> q_exp -> q_rr -> q_out;
  }
  store -> q_rrf [style=dashed, label="vec+fts"];
  store -> q_exp [style=dashed, label="links"];

  /* ---------------- SENTINEL ---------------- */
  subgraph cluster_sentinel {
    label="SENTINEL  (on write / on demand)  +  BELIEF-DRIFT";
    style="rounded,filled"; color="#f0a875"; fillcolor="#fff1e8"; fontcolor="#9a4a16";
    s_new   [label="new / edited claim"];
    s_cull  [label="similarity cull\n(embedding, API)"];
    s_filt  [label="assertion filter\n(deterministic)"];
    s_judge [label="Judge\nhost LLM (tool-result)"];
    s_ref   [label="temporal reframe\n'changed your mind'"];
    s_learn [label="confirm-and-learn\n3-tier suppression"];
    s_git   [label="git log -G / show\n→ arc compress", shape=note, fillcolor="#fff8f2"];
    s_new -> s_cull -> s_filt -> s_judge -> s_ref -> s_learn;
    s_git -> s_judge [label="drift narrate"];
  }
  store -> s_cull [style=dashed, label="claims"];
  s_learn -> store [style=dashed, label="labels"];
}
