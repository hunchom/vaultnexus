# VaultNexus daemon environment.
# Copy to .env (or a shell rc) and source before `node dist/daemon/main.js`.
# Do NOT commit secrets. .env is gitignored — keep it that way.

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Absolute path to the Markdown vault to index.
VAULTNEXUS_VAULT="/Users/you/Documents/MyVault"

# ── HTTP ─────────────────────────────────────────────────────────────────────
# Loopback port the daemon binds. Plugin reads this in its settings; keep
# them in sync.
# VAULTNEXUS_HTTP_PORT=38473

# ── EMBEDDER ─────────────────────────────────────────────────────────────────
# Unset → offline FakeEmbedder (low quality, fine for smoke tests).
# Set ALL THREE for a real OpenAI-compatible /embeddings endpoint.

# Voyage AI — strong general-purpose embedder
# VAULTNEXUS_EMBED_URL="https://api.voyageai.com/v1"
# VAULTNEXUS_EMBED_KEY="<your-voyage-key>"
# VAULTNEXUS_EMBED_MODEL="voyage-3-large"

# OpenAI
# VAULTNEXUS_EMBED_URL="https://api.openai.com/v1"
# VAULTNEXUS_EMBED_KEY="<your-openai-key>"
# VAULTNEXUS_EMBED_MODEL="text-embedding-3-small"

# Ollama (local, offline, free)
#   ollama pull nomic-embed-text
# VAULTNEXUS_EMBED_URL="http://localhost:11434/v1"
# VAULTNEXUS_EMBED_KEY="ollama"
# VAULTNEXUS_EMBED_MODEL="nomic-embed-text"

# ── SNAPSHOT ─────────────────────────────────────────────────────────────────
# On-disk snapshot path. Default ~/.vaultnexus/index-snapshot.db.
# Set to the literal string "off" to disable persistence.
# VAULTNEXUS_INDEX_SNAPSHOT="off"

# ── CHAT MODEL (optional — only needed for reason / narrate / recall tools) ─
# Default: fake (offline stub). Plugin can also push this live via
# POST /configure-chat — no daemon restart required.

# Anthropic
# VAULTNEXUS_CHAT_PROVIDER="anthropic"
# VAULTNEXUS_CHAT_KEY="<your-anthropic-key>"
# VAULTNEXUS_CHAT_MODEL="claude-sonnet-4-6"   # optional; defaults to claude-sonnet-4-6

# OpenAI
# VAULTNEXUS_CHAT_PROVIDER="openai"
# VAULTNEXUS_CHAT_KEY="<your-openai-key>"
# VAULTNEXUS_CHAT_MODEL="gpt-4o-mini"          # optional; defaults to gpt-4o-mini

# OpenAI-compatible (Ollama, LM Studio, vLLM)
# VAULTNEXUS_CHAT_PROVIDER="openai-compatible"
# VAULTNEXUS_CHAT_URL="http://localhost:11434/v1"
# VAULTNEXUS_CHAT_KEY="ollama"
# VAULTNEXUS_CHAT_MODEL="llama3.1:8b"
